<Window x:Class="ParshakovaWpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ParshakovaWpf"
        mc:Ignorable="d"
        Title="ParshakovaWPF" Height="600" Width="800" ResizeMode="NoResize" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <DataTemplate x:Key="listTemplate">
            <StackPanel Margin="4">
                <TextBlock FontSize="12" Text="{Binding Path=Name}" HorizontalAlignment="Center" />
            </StackPanel>
        </DataTemplate>
    </Window.Resources>
    <Grid x:Name="MainLayout">
        <DockPanel>
            <Menu DockPanel.Dock="Top" MinHeight="25">
                <MenuItem Header="Партнеры">
                    <MenuItem Header="Добавить партнера" Click="AddPartner_Click"/>
                    <MenuItem Header="Редактировать партнера" Click="EditPartner_Click"/>
                    <Separator/>
                    <MenuItem Header="Удалить партнера" Click="DeletePartner_Click"/>
                </MenuItem>
                <MenuItem Header="Продукция">
                    <MenuItem Header="Добавить продажу" Click="AddSale_Click"/>
                    <MenuItem Header="Редактировать продажу" Click="EditSale_Click"/>
                    <Separator/>
                    <MenuItem Header="Удалить продажу" Click="DeleteSale_Click"/>
                </MenuItem>
                <MenuItem Header="Выход" Click="Exit_Click"/>
            </Menu>

            <ListBox x:Name="PartnersList" Width="300" ItemsSource="{Binding Partners}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="Gray" BorderThickness="1" Margin="5" Padding="16" HorizontalAlignment="Stretch">
                            <Grid HorizontalAlignment="Stretch" Width="240">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock FontWeight="Bold">
                            <Run Text="{Binding Type}" />
                            <Run Text=" | " />
                            <Run Text="{Binding Name}" />
                                    </TextBlock>
                                    <TextBlock Text="{Binding Director}" Margin="0,5,0,0"/>
                                    <TextBlock Text="{Binding Phone, StringFormat={}{0}}" Margin="0,5,0,0"/>
                                    <TextBlock Margin="0,5,0,0">
                            <Run Text="Рейтинг: " />
                            <Run Text="{Binding Rating}" />
                                    </TextBlock>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="{Binding DisplayDiscountPercent, StringFormat={}{0:F0}%}" VerticalAlignment="Center" HorizontalAlignment="Right" FontWeight="Bold" Margin="10,0,0,0"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Добавить партнера" Click="AddPartner_Click" />
                        <MenuItem Header="Редактировать партнера" Click="EditPartner_Click" />
                        <Separator/>
                        <MenuItem Header="Удалить партнера" Click="DeletePartner_Click"/>
                    </ContextMenu>
                </ListBox.ContextMenu>
            </ListBox>

            <Grid Grid.Column="1" Margin="10" Background="White">
                <TextBlock FontSize="16" FontWeight="SemiBold" Text="Данные" Margin="0,0,0,10" Foreground="Black"/>
                <DataGrid x:Name="SalesDataGrid" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" HeadersVisibility="Column" 
              CanUserSortColumns="False" Background="White" Margin="0,-10,0,4" SelectionMode="Single">
                    <DataGrid.Resources>
                        <Style x:Key="CenterTextStyle" TargetType="TextBlock">
                            <Setter Property="TextAlignment" Value="Center"/>
                        </Style>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Наименование" Binding="{Binding Path=ProductName}" Width="*" >
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="Black"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                            <DataGridTextColumn.EditingElementStyle>
                                <Style TargetType="TextBox">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="Black"/>
                                </Style>
                            </DataGridTextColumn.EditingElementStyle>

                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Дата продажи" Binding="{Binding Path=Date, StringFormat={}{0:dd.MM.yyyy}}" Width="*" CanUserResize="True"   >
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="TextAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                            <DataGridTextColumn.EditingElementStyle>
                                <Style TargetType="TextBox">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="Black"/>
                                </Style>
                            </DataGridTextColumn.EditingElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Количество" Binding="{Binding Path=Quantity}" Width="*" >
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="Black"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                            <DataGridTextColumn.EditingElementStyle>
                                <Style TargetType="TextBox">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="Black"/>
                                </Style>
                            </DataGridTextColumn.EditingElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Добавить продажу" Click="AddSale_Click"/>
                            <MenuItem Header="Редактировать продажу" Click="EditSale_Click"/>
                            <Separator/>
                            <MenuItem Header="Удалить продажу" Click="DeleteSale_Click"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                </DataGrid>

            </Grid>
        </DockPanel>
    </Grid>
</Window>

