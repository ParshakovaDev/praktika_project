<Window x:Class="ParshakovaWpf.SaleAddEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ParshakovaWpf"
        mc:Ignorable="d"
        Title="Добавить/Редактировать продажу" Height="290" Width="340" ResizeMode="CanMinimize" WindowStartupLocation="CenterOwner">
    <Grid>
        <StackPanel Margin="10">
            <TextBlock Text="Наименование" Margin="0,0,0,5"/>
            <TextBox x:Name="ProductNameTextBox" Margin="0,0,0,10" />

            <TextBlock Text="Дата продажи" Margin="0,0,0,5"/>
            <DatePicker x:Name="SaleDatePicker" Margin="0,0,0,10" />

            <TextBlock Text="Кол-во" Margin="0,0,0,5"/>
            <TextBox x:Name="QuantityTextBox" Margin="0,0,0,10" />

            <Button Content="Сохранить" Click="SaveButton_Click"  Width="90" Height="25"/>
            <Label/>
            <Label/>
            <Button Content="Отменить" Click="CancelButton_Click"  Width="90" Height="25"/>

        </StackPanel>
    </Grid>
</Window>